# =============================================================================
# MedHarmony Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# --- Google Gemini API ---
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-3.0-flash

# --- A2A Agent Server ---
A2A_HOST=0.0.0.0
A2A_PORT=8000
A2A_AGENT_NAME=MedHarmony
A2A_AGENT_URL=http://localhost:8000

# --- MCP Servers ---
FHIR_MCP_PORT=8001
DRUG_MCP_PORT=8002
GUIDELINES_MCP_PORT=8003

# --- FHIR Server ---
# Use a public FHIR test server or your own
FHIR_SERVER_URL=https://hapi.fhir.org/baseR4
FHIR_AUTH_TOKEN=

# --- OpenFDA / RxNorm ---
OPENFDA_API_KEY=
RXNORM_API_URL=https://rxnav.nlm.nih.gov/REST

# --- Prompt Opinion ---
PO_PLATFORM_URL=https://app.promptopinion.ai
PO_MARKETPLACE_ID=

# --- Logging ---
LOG_LEVEL=INFO
